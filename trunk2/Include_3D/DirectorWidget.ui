  <property name="styleSheet">
   <string notr="true">/* 整体背景与文字 */
QWidget#DirectorWidgetClass {
    background-color: #1e1e1e;
    color: #e0e0e0;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 13px;
}

/* 资源列表与表格通用样式 */
QListWidget, QTableWidget {
    background-color: #252526;
    border: 1px solid #3f3f46;
    border-radius: 4px;
    color: #d4d4d4;
    gridline-color: #333333;
    selection-background-color: #094771;
    selection-color: #ffffff;
    outline: none;
}

/* 表格表头 */
QHeaderView::section {
    background-color: #333333;
    color: #cccccc;
    padding: 6px;
    border: none;
    border-right: 1px solid #3f3f46;
    border-bottom: 1px solid #3f3f46;
    font-weight: bold;
}

/* 按钮通用样式 */
QPushButton {
    background-color: #3e3e42;
    color: white;
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 6px 12px;
    min-width: 60px;
}

QPushButton:hover {
    background-color: #505050;
    border: 1px solid #007acc;
}

QPushButton:pressed {
    background-color: #007acc;
}

/* 播放按钮特殊高亮 (假设对象名是 btn_play) */
QPushButton#btn_play {
    background-color: #0e639c;
    border: none;
    font-weight: bold;
}

QPushButton#btn_play:hover {
    background-color: #1177bb;
}

/* 下拉框与微调框 (表格内部件) */
QComboBox, QSpinBox {
    background-color: #3c3c3c;
    color: #cccccc;
    border: 1px solid #555555;
    padding: 2px 5px;
}

/* 自定义滚动条 - 让它看起来像专业软件 */
QScrollBar:vertical {
    border: none;
    background: #1e1e1e;
    width: 10px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background: #4f4f4f;
    min-height: 20px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover {
    background: #6f6f6f;
}

/* 设置左侧垂直表头的背景 */
QHeaderView::section:vertical {
    background-color: #333333; /* 与水平表头一致的深灰色 */
    color: #aaaaaa;            /* 文字颜色 */
    padding-left: 5px;
    padding-right: 5px;
    border: none;
    border-bottom: 1px solid #3f3f46; /* 行分割线 */
    min-width: 30px;
}

/* 整个表头区域的背景色（防止出现空白边角） */
QTableWidget QHeaderView {
    background-color: #333333;
}

/* 选中某行时，左侧表头的高亮样式 */
QHeaderView::section:vertical:checked {
    background-color: #094771;
    color: white;
}
QTableWidget QTableCornerButton::section {
    background-color: #333333; /* 设置为与表头一样的颜色 */
    border: none;
}
</string>
